# .env — Pookies POS Configuration

# Environment
NODE_ENV=production

# Server Ports
PORT=3001                  # Express/API server
VITE_PORT=5174             # Vite development server
ELECTRON_PORT=5174         # Used by Electron in development mode

# Database
DB_PATH=./pookies_inventory.db

# Inventory Thresholds
LOW_STOCK_ALERT_DAYS=7
LOG_RETENTION_DAYS=30

# API Configuration
API_BASE_URL=http://localhost:3001
VITE_API_URL=http://localhost:3001

# CORS Settings
CORS_ORIGIN=http://localhost:5174

# Receipt Uploads
MAX_FILE_SIZE=10485760     # 10 MB in bytes

# Application
APP_NAME=Pookies POS
APP_VERSION=1.0.0